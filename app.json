{
  "expo": {
    "name": "neura-home",
    "slug": "neura-home",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/png/logoGradientSquareNoText.png",
    "scheme": "neurahome",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Used to discover Home Assistant on your local network",
        "NSBonjourServices": [
          "_home-assistant._tcp",
          "_home-assistant._tcp"
        ]
      },
      "bundleIdentifier": "com.neurahome.app"
    },
    "android": {
      "package": "com.neurahome.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/png/logoGradientSquareNoText.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/png/logoGradientSquareNoText.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-audio",
        {
          "recordAudioAndroid": "true",
          "microphonePermission": "Allow Neura Home to access your microphone."
        }
      ],
      ["expo-speech-recognition", {
        "microphonePermission": "Allow Neura Home to access your microphone.",
        "speechRecognitionPermission": "Allow Neura Home to access your speech recognition."
      }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
